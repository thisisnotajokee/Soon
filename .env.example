# Minimum required environment for Soon v1

# API bind
HOST=127.0.0.1
PORT=3100

# Storage mode: memory | postgres
SOON_DB_MODE=memory

# Required only for postgres mode
# SOON_DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname
# SOON_DATABASE_SSL=0
# SOON_READ_MODEL_REFRESH_MODE=async

# Optional alert checker thresholds
# SOON_ALERT_BASE_URL=http://127.0.0.1:3100
# SOON_ALERT_PENDING_WARN=3
# SOON_ALERT_PENDING_CRIT=10
# SOON_ALERT_DURATION_WARN_MS=5000
# SOON_ALERT_DURATION_CRIT_MS=15000
# SOON_ALERT_STUCK_SEC=300
