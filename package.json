{
  "name": "soon",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/src/runtime/server.mjs\"",
    "dev:api:postgres": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; SOON_DB_MODE=postgres node packages/api/src/runtime/server.mjs\"",
    "db:migrate": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/run-migrations.mjs\"",
    "db:cleanup:legacy:preview": "node packages/api/scripts/cleanup-legacy-backup.mjs --retention-days=30",
    "db:cleanup:legacy:execute": "node packages/api/scripts/cleanup-legacy-backup.mjs --retention-days=30 --execute",
    "obs:read-model:alert:check": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/read-model-alert-check.mjs\"",
    "obs:read-model:alert:check:json": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/read-model-alert-check.mjs --json\"",
    "obs:doctor:report": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/doctor-report.mjs\"",
    "obs:doctor:report:json": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/doctor-report.mjs --json-only\"",
    "obs:doctor:summary": "node packages/api/scripts/doctor-summary.mjs",
    "ops:self-heal:triage:validate": "node packages/api/scripts/self-heal-triage-validate.mjs",
    "ops:self-heal:requeue:triage": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/self-heal-requeue-triage.mjs\"",
    "ops:self-heal:requeue:triage:json": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/api/scripts/self-heal-requeue-triage.mjs --json\"",
    "test:contracts": "node --test packages/api/test/contracts-v1.test.mjs",
    "test:workers": "node --test packages/api/test/workers-v1.test.mjs",
    "test:scripts": "node --test packages/api/test/scripts-v1.test.mjs",
    "smoke:e2e": "bash -lc \"set -a; [ -f .env.local ] && source .env.local; set +a; node packages/web/smoke/e2e-smoke.mjs\"",
    "check": "npm run test:contracts && npm run test:workers && npm run test:scripts && npm run smoke:e2e"
  },
  "dependencies": {
    "pg": "^8.16.3"
  }
}
